# Copy to .env and fill in (cp .env.example .env). .env is gitignored.
# Token: https://ux.priorlabs.ai → License tab

# Required for TabPFN 2.5+ model download when not using interactive browser auth:
TABPFN_TOKEN=

# Optional (defaults are fine for most headless / cluster runs)
TABPFN_NO_BROWSER=1
TABPFN_DISABLE_TELEMETRY=1

# Optional: read token from a file instead of inline (path can be in .env too)
# TABPFN_TOKEN_FILE=/scratch/yournetid/.tabpfn_token
